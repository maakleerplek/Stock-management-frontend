(site_config) {
	encode gzip

	@health path /health
	handle @health {
		respond "healthy" 200
	}

	# Security headers
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
	}

	# Cache static assets
	@cache_assets {
		path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot
	}
	header @cache_assets Cache-Control "public, max-age=31536000, immutable"

	# Proxy API calls directly to InvenTree backend
	# Uses INVENTREE_BACKEND_URL env var, defaults to localhost:8080
	# Forward all headers including Authorization
	handle /api/* {
		reverse_proxy {$INVENTREE_BACKEND_URL:http://localhost:8080} {
			header_up Host {upstream_hostport}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Proxy Media requests (images) to InvenTree backend
	# Uses INVENTREE_BACKEND_URL env var, defaults to localhost:8080
	# Forward all headers including Authorization for authenticated media access
	handle /media/* {
		reverse_proxy {$INVENTREE_BACKEND_URL:http://localhost:8080} {
			header_up Host {upstream_hostport}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# SPA fallback: route all non-existent files to index.html
	handle {
		try_files {path} /index.html
		file_server {
			root /usr/share/caddy
		}
	}
}

http://localhost, http://127.0.0.1, http://192.168.68.64 {
	import site_config
}

https://localhost, https://127.0.0.1, https://192.168.68.64, https://172.20.0.2 {
	tls internal
	import site_config
}


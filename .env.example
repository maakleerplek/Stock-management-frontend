# =============================================================================
# ORGANIZATION DETAILS
# =============================================================================
# Organization name (displayed in footer and payment details)
VITE_ORGANIZATION_NAME="Your Organization Name"
# Organization website URL (linked from logo)
VITE_ORGANIZATION_URL="https://your-organization.com/"

# =============================================================================
# INVENTREE API CONNECTION
# =============================================================================
# IMPORTANT: Leave this EMPTY to use relative URLs through the Caddy proxy
# This prevents mixed content errors (HTTP/HTTPS) and ensures all requests
# go through the HTTPS Caddy reverse proxy
VITE_INVENTREE_URL=

# InvenTree API token (generate from InvenTree: Settings -> API Tokens)
VITE_INVENTREE_TOKEN=your-inventree-api-token-here

# Backend URL for Caddy to proxy API and media requests to InvenTree
# This is used at runtime by the Caddy reverse proxy (from Docker container's perspective)
# Use the IP/hostname that the Docker container can reach
INVENTREE_BACKEND_URL=http://192.168.1.100:8080

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Password for volunteer/simplified access mode
# DEPRECATED: temporary fallback. Remove once Microsoft sign-in is verified
# in production (see GitHub issue "Remove volunteer password login").
VITE_VOLUNTEER_PASSWORD=volunteer

# --- Microsoft Entra ID (Azure AD) sign-in for volunteers ---
# Create an Entra "App registration" (platform: Single-page application),
# add your site URL(s) as Redirect URIs, and paste the values below.
# Leave BOTH blank to disable Microsoft sign-in (password fallback still works).
#
# Application (client) ID from the app registration overview
VITE_AZURE_CLIENT_ID=
# Directory (tenant) ID — single-tenant: only this org's accounts can sign in
VITE_AZURE_TENANT_ID=
# Optional: explicit redirect URI. Defaults to the site's own origin if blank.
# Must EXACTLY match a Redirect URI registered in Entra (e.g. https://stock.example.org).
VITE_AZURE_REDIRECT_URI=

# =============================================================================
# PRICING - EXTRA SERVICES
# =============================================================================
# Price per minute for laser cutting service
VITE_LASER_PRICE_PER_MIN=0.50
# Price per gram for 3D printing service
VITE_PRINT_PRICE_PER_GRAM=0.10
# Currency code (EUR, USD, GBP, etc.)
VITE_CURRENCY=EUR

# =============================================================================
# WERO (EPC QR) PAYMENT INTEGRATION
# =============================================================================
# Name to appear on QR payment requests
VITE_PAYMENT_NAME="Your Organization Name"
# IBAN for receiving payments
VITE_PAYMENT_IBAN="BE00000000000000"
# Payconiq Merchant ID for Payconiq payment link (optional, leave empty if not using Payconiq)
VITE_PAYCONIQ_MERCHANT_ID=""

# =============================================================================
# FOOTER LINKS CONFIGURATION
# =============================================================================
# Link to InvenTree documentation
VITE_DOCS_URL="https://docs.inventree.org/en/stable/"
# Link to feedback form (optional)
VITE_FEEDBACK_URL="https://your-feedback-url.com"
# Link to GitHub repository (optional)
VITE_GITHUB_URL="https://github.com/your-org/your-repo"

# =============================================================================
# TV PRESENTATION INTEGRATION
# =============================================================================
# URL of the tv-presentation Next.js server (e.g. http://10.72.3.141:8083)
# Leave empty to disable changelog reporting
VITE_TV_PRESENTATION_URL=http://10.72.3.68:8083

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
# HTTP port for frontend (default: 8082)
FRONTEND_HTTP_PORT=8082
# HTTPS port for frontend (default: 8444)
FRONTEND_HTTPS_PORT=8444
